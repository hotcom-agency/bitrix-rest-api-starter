{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Listen for XDebug",
      "type": "php",
      "request": "launch",
      "port": 9003,
      "hostname": "localhost",
      "pathMappings": {
        "/var/www/html": "${workspaceFolder}"
      },
      "ignore": [
        "/var/www/html/bitrix/**",
        "/var/www/html/vendor/**"
      ],
      "xdebugSettings": {
        "max_children": 128,
        "max_depth": 5
      }
    },
    {
      "name": "Launch Currently Open Script",
      "type": "php",
      "request": "launch",
      "program": "${file}",
      "cwd": "${fileDirname}",
      "port": 9003
    }
  ]
}
